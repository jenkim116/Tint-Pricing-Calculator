# Optional: Google Sheets — append each lead submission as a row.
#
# Option A — Apps Script (no service account key; use if your org blocks key creation):
#   1. See docs/google-sheets-apps-script.js for the script to paste in your Sheet.
#   2. Deploy as Web app (Anyone), then set:
GOOGLE_APPS_SCRIPT_WEBHOOK_URL=https://script.google.com/macros/s/xxxx/exec
#
# Option B — Service account (needs JSON key from Google Cloud):
# GOOGLE_SHEET_ID=your_spreadsheet_id_from_url
# GOOGLE_CLIENT_EMAIL=your-service-account@project.iam.gserviceaccount.com
# GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
#
# Optional: Email estimate PDF — for "Email me this estimate" button (Resend).
# Get an API key at https://resend.com. Use a verified domain for ESTIMATE_EMAIL_FROM in production.
# RESEND_API_KEY=re_xxxx
# ESTIMATE_EMAIL_FROM=Vizta Tint <hello@yourdomain.com>
